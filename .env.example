# ==========================================
# Data Platform Demo — 环境变量配置模板
# 复制此文件为 .env 并修改为你自己的配置
# ==========================================

# ---- 数据库 ----
DATA_PLATFORM_DB_HOST=data-platform-db
DATA_PLATFORM_DB_PORT=5432
DATA_PLATFORM_DB_USER=admin
DATA_PLATFORM_DB_PASSWORD=changeme
DATA_PLATFORM_DB_NAME=data_platform

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVER=kafka:29092
KAFKA_TOPIC=events

# ---- Airflow ----
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow

# ---- 可选: Ubuntu VM (PySpark 远端执行) ----
# VM_HOST=
# VM_PORT=2222
# VM_USER=
# VM_PASS=

# ---- 运行环境 ----
ENV=dev

# ---- AI/ML 组件 ----
# Milvus (向量数据库)
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Embedding 模型
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# FAISS 知识库
RAG_INDEX_PATH=rag_demo/knowledge_base/index.faiss
RAG_META_PATH=rag_demo/knowledge_base/metadata.json

# Feast 特征平台
FEAST_REPO_PATH=feast/feature_repo
