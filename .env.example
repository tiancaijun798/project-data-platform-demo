# ==========================================
# Data Platform Demo — 环境变量配置模板
# 复制此文件为 .env 并修改为你自己的配置
# ==========================================

# ---- 数据库 ----
DATA_PLATFORM_DB_HOST=data-platform-db
DATA_PLATFORM_DB_PORT=5432
DATA_PLATFORM_DB_USER=admin
DATA_PLATFORM_DB_PASSWORD=changeme
DATA_PLATFORM_DB_NAME=data_platform

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVER=kafka:29092
KAFKA_TOPIC=events

# ---- Airflow ----
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow

# ---- 可选: Ubuntu VM (PySpark 远端执行) ----
# VM_HOST=
# VM_PORT=2222
# VM_USER=
# VM_PASS=

# ---- 运行环境 ----
ENV=dev
